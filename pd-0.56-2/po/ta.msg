::msgcat::mcset ta "All Files" "\u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0b95\u0bc7\u0bbe\u0baa\u0bcd\u0baa\u0bc1\u0b95\u0bb3\u0bcd"
